[cisco_ios]
leaf01 ansible_host=192.168.1.10
leaf02 ansible_host=192.168.1.11

[arista_eos]
edge01 ansible_host=10.0.0.5
edge02 ansible_host=10.0.0.6

# Variables applied to all hosts in the cisco_ios group
[cisco_ios:vars]
ansible_connection=ansible.netcommon.network_cli
ansible_network_os=cisco.ios.ios
ansible_user=admin
ansible_become=yes
ansible_become_method=enable

# Variables applied to all hosts in the juniper_junos group
[arista_eos:vars]
ansible_connection=ansible.netcommon.netconf
ansible_network_os=arista.eos.eos
ansible_user=ec2-user
ansible_become=yes
ansible_become_method=enable

# Parent group that includes multiple child groups
[all_switches:children]
cisco_ios
arist_eos

